FROM dustynv/pytorch:2.7-r36.4.0

# Jetson Orin: JetPack 6.x, CUDA 12.8, Python 3.10+, PyTorch 2.7
# PyTorch and torchvision are pre-installed in the base image

# setup environment
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

WORKDIR /roboml

COPY . .

RUN apt-get update && apt-get install -y ffmpeg libsm6 libxext6 && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip3 install .

# clean up source
RUN rm -rf /roboml
